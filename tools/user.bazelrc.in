startup --output_user_root=@DASHBOARD_OUTPUT_USER_ROOT@
startup --max_idle_secs=99

common --announce_rc=yes
common --build_event_json_file=@DASHBOARD_BUILD_EVENT_JSON_FILE@
common --color=yes
common --curses=no
common --progress_report_interval=5
common --experimental_repository_downloader_retries=5
common --experimental_ui_max_stdouterr_bytes=5242880
common --experimental_scale_timeouts=@DASHBOARD_EXPERIMENTAL_SCALE_TIMEOUTS@
common --http_timeout_scaling=@DASHBOARD_EXPERIMENTAL_SCALE_TIMEOUTS@

build --copt=@DASHBOARD_COPT@
build --host_copt=@DASHBOARD_COPT@
build --jobs=@DASHBOARD_JOBS@
build --keep_going=yes
build --subcommands=@DASHBOARD_SUBCOMMANDS@
build --test_env=GRB_LICENSE_FILE
build --test_env=MOSEKLM_LICENSE_FILE

fetch --keep_going=yes

query --keep_going=yes

test --test_summary=short

try-import %workspace%/remote.bazelrc
